<div class="mx-auto max-w-6xl px-4 py-8">

  <!-- Header -->
  <div class="flex items-center justify-between mb-8">
    <h1 class="text-3xl font-bold text-gray-900"><%= @course.name %></h1>

    <div class="flex gap-3">
      <%= link_to "Edit Course",
          edit_course_path(@course),
          class: "inline-flex items-center rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow hover:bg-indigo-500" %>

      <%= link_to "Delete",
          @course,
          data: { turbo_method: :delete, turbo_confirm: "Are you sure you want to delete this course?" },
          class: "inline-flex items-center rounded-md bg-red-600 px-4 py-2 text-sm font-semibold text-white shadow hover:bg-red-500" %>
    </div>
  </div>

  <%# ====================== COURSE DETAILS ====================== %>
  <div class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm mb-10">
    <h2 class="text-2xl font-semibold text-gray-900 mb-4">Course Details</h2>

    <% if @course.description.present? %>
      <p class="text-gray-700 leading-relaxed"><%= @course.description %></p>
    <% else %>
      <p class="text-gray-400 text-sm">No description provided.</p>
    <% end %>
  </div>


  <%# ====================== MODULES SECTION ====================== %>
  <div class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm mb-10">
    <div class="flex items-center justify-between">
      <h2 class="text-2xl font-semibold text-gray-900">Modules</h2>

      <%= link_to "Add Module",
          new_course_module_path(course_id: @course.id),
          class: "inline-flex items-center rounded-md bg-blue-600 px-4 py-2 text-sm font-semibold text-white shadow hover:bg-blue-500" %>
    </div>

    <% if @course.course_modules.any? %>
      <ul class="mt-6 space-y-4">
        <% @course.course_modules.order(:name).each do |mod| %>
          <li class="p-4 bg-gray-50 rounded-lg border border-gray-200 hover:shadow transition">
            <div class="flex items-center justify-between">

              <div>
                <h3 class="text-lg font-semibold text-gray-900"><%= mod.name %></h3>
                <% if mod.respond_to?(:description) && mod.description.present? %>
                  <p class="mt-1 text-sm text-gray-600"><%= mod.description %></p>
                <% end %>
              </div>

              <div class="flex gap-3">
                <%= link_to "Edit",
                    edit_course_module_path(mod),
                    class: "text-indigo-600 hover:underline text-sm font-medium" %>

                <%= link_to "Delete",
                    mod,
                    data: { turbo_method: :delete, turbo_confirm: "Delete this module?" },
                    class: "text-red-600 hover:underline text-sm font-medium" %>
              </div>

            </div>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="mt-4 text-gray-600">No modules added yet.</p>
    <% end %>
  </div>


  <%# ====================== STUDENTS ON THIS COURSE ====================== %>
  <div class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm">
    <h2 class="text-2xl font-semibold text-gray-900 mb-4">Students Enrolled</h2>

    <% if @course.students.any? %>
      <ul class="divide-y divide-gray-200">

        <% @course.students.order(:name).each do |student| %>
          <li class="py-4 flex items-center justify-between">

            <div>
              <h3 class="text-lg font-medium text-gray-900">
                <%= link_to student.name, student, class: "hover:underline" %>
              </h3>

              <% if student.start_date.present? %>
                <p class="text-sm text-gray-600">
                  Started:
                  <%= student.start_date.strftime("%d %b %Y") %>
                </p>
              <% end %>
            </div>

            <%= link_to "View",
                student_path(student),
                class: "inline-flex items-center rounded-md bg-gray-800 px-3 py-1.5 text-sm font-semibold text-white shadow hover:bg-gray-700" %>
          </li>
        <% end %>

      </ul>
    <% else %>
      <p class="text-gray-600">No students are enrolled on this course yet.</p>
    <% end %>
  </div>

</div>