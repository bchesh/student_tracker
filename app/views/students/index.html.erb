<div class="mx-auto max-w-6xl px-4 py-8">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-semibold text-gray-900">Students</h1>
    <%= link_to "New student",
        new_student_path,
        class: "inline-flex items-center rounded-md bg-blue-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-blue-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-600" %>
  </div>

  <div class="overflow-hidden rounded-lg border border-gray-200 bg-white shadow-sm">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider text-gray-600">Name</th>
          <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider text-gray-600">Course</th>
          <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider text-gray-600">Start</th>
          <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider text-gray-600">End</th>
          <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider text-gray-600">Status</th>
          <th class="px-4 py-3 text-right text-xs font-medium uppercase tracking-wider text-gray-600">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100 bg-white">
        <% @students.each do |student| %>
          <tr class="hover:bg-gray-50">
            <td class="px-4 py-3">
              <div class="font-medium text-gray-900"><%= link_to student.name, student, class: "hover:underline" %></div>
              <div class="text-xs text-gray-500"><%= student.email if student.respond_to?(:email) %></div>
            </td>
            <td class="px-4 py-3 text-gray-700">
              <% if student.courses.any? %>
                <%= student.courses.map(&:name).join(", ") %>
              <% else %>
                <span class="text-gray-400">No courses</span>
              <% end %>
            </td>
            <td class="px-4 py-3 text-gray-700"><%= student.start_date&.strftime("%d %b %Y") %></td>
            <td class="px-4 py-3 text-gray-700"><%= student.end_date&.strftime("%d %b %Y") %></td>
            <td class="px-4 py-3">
              <%= status_badge(student.status) %>
            </td>
            <td class="px-4 py-3">
              <div class="flex justify-end gap-2">
                <%= link_to "View", student, class: "inline-flex items-center rounded-md border border-gray-300 bg-white px-3 py-1.5 text-sm font-medium text-gray-700 hover:bg-gray-50" %>
                <%= link_to "Edit", edit_student_path(student), class: "inline-flex items-center rounded-md bg-indigo-600 px-3 py-1.5 text-sm font-medium text-white hover:bg-indigo-500" %>
                <%= link_to "Delete", student, data: { turbo_method: :delete, turbo_confirm: "Delete this student?" },
                      class: "inline-flex items-center rounded-md bg-red-600 px-3 py-1.5 text-sm font-medium text-white hover:bg-red-500" %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>