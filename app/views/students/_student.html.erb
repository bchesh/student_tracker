<div id="<%= dom_id student %>" class="w-full sm:w-auto my-5 space-y-5">
  <div>
    <strong class="block font-medium mb-1">Name:</strong>
    <%= student.name %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Course:</strong>
    <%= student.course %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Start date:</strong>
    <%= student.start_date %>
  </div>
  <div>
    <strong class="block font-medium mb-1">End date:</strong>
    <%= student.end_date %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Notes:</strong>
    <%= student.notes %>
  </div>
</div>
