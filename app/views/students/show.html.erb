<div class="mx-auto max-w-6xl px-4 py-8">

  <!-- Header -->
  <div class="flex items-center justify-between mb-8">
    <h1 class="text-3xl font-bold text-gray-900"><%= @student.name %></h1>

    <%= link_to "Edit Student",
      edit_student_path(@student),
      class: "inline-flex items-center rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow hover:bg-indigo-500" %>

        <%= link_to "Enrol on a new course",
    new_enrollment_path(student_id: @student.id),
    class: "inline-flex items-center rounded-md bg-blue-600 px-4 py-2 text-sm font-semibold text-white hover:bg-blue-500" %>
  </div>

  <!-- ================= STUDENT INFO SECTION ================= -->
  <h2 class="text-2xl font-semibold text-gray-900 mb-4">Student Information</h2>
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-10">

    <% if @student.email.present? %>
      <div class="rounded-md bg-gray-50 p-4">
        <dt class="text-xs uppercase tracking-wide text-gray-500">Email</dt>
        <dd class="mt-1 text-sm text-gray-800"><%= @student.email %></dd>
      </div>
    <% end %>

    <% if @student.phone.present? %>
      <div class="rounded-md bg-gray-50 p-4">
        <dt class="text-xs uppercase tracking-wide text-gray-500">Phone</dt>
        <dd class="mt-1 text-sm text-gray-800"><%= @student.phone %></dd>
      </div>
    <% end %>

  </div>

  <!-- ================= CURRENT COURSE SECTION ================= -->
  <h2 class="text-2xl font-semibold text-gray-900 mb-4">Current Course/s</h2>
  <% current = @student.enrollments.order(start_date: :desc).first %>

  <% if current.present? %>
    <div class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm mb-10">
      <h3 class="text-xl font-bold text-gray-900">
        <%= link_to current.course.name, current.course, class: "hover:underline" %>
      </h3>

      <p class="mt-1 text-gray-600">
        <strong>Start:</strong> <%= current.start_date&.strftime("%d %b %Y") %><br>
        <strong>End:</strong> <%= current.end_date&.strftime("%d %b %Y") %><br>
        <strong>Status:</strong> <%= current.status || "Active" %>
      </p>

      <!-- COURSE PERCENTAGE -->
      <% total = current.student_modules.count %>
      <% completed = current.student_modules.where(status: "PASSED").count %>
      <% percent = total > 0 ? (completed.to_f / total * 100).round : 0 %>

      <div class="mt-4">
        <p class="text-gray-700 font-medium">Course Progress: <%= percent %>%</p>
        <div class="w-full bg-gray-200 h-3 rounded mt-1">
          <div class="bg-green-500 h-3 rounded" style="width: <%= percent %>%"></div>
        </div>
      </div>

      <!-- MODULES LIST -->
      <h4 class="mt-6 text-xl font-semibold">Modules</h4>

      <% if current.student_modules.any? %>
        <ul class="mt-4 space-y-4">
          <% current.student_modules.includes(:course_module).each do |mod| %>
            <%= render "module_status_row", course_module: mod.course_module, student_module: mod %>
          <% end %>
        </ul>
      <% else %>
        <p class="text-gray-600 mt-2">No modules assigned for this course.</p>
      <% end %>
    </div>
  <% else %>
    <p class="text-gray-600 mb-10">This student is not enrolled on any course.</p>
  <% end %>


  <!-- ================= PAST COURSES SECTION ================= -->
  <h2 class="text-2xl font-semibold text-gray-900 mb-4">Past Courses</h2>

  <% past = @student.enrollments.order(start_date: :desc).offset(1) %>

  <% if past.any? %>
    <% past.each do |enrollment| %>
      <div class="rounded-lg border border-gray-200 p-6 mb-6 bg-white shadow-sm">
        <h3 class="text-xl font-bold text-gray-900">
          <%= link_to enrollment.course.name, enrollment.course, class: "hover:underline" %>
        </h3>

        <p class="text-gray-600 mt-1">
          <strong>Start:</strong> <%= enrollment.start_date&.strftime("%d %b %Y") %><br>
          <strong>End:</strong> <%= enrollment.end_date&.strftime("%d %b %Y") %><br>
          <strong>Status:</strong> <%= enrollment.status || "Completed" %>
        </p>

        <h4 class="mt-4 text-lg font-semibold">Modules</h4>

        <% if enrollment.student_modules.any? %>
          <ul class="mt-2 space-y-3">
            <% enrollment.student_modules.includes(:course_module).each do |mod| %>
              <%= render "module_status_row", course_module: mod.course_module, student_module: mod %>
            <% end %>
          </ul>
        <% else %>
          <p class="text-gray-600">No module history found.</p>
        <% end %>
      </div>
    <% end %>
  <% else %>
    <p class="text-gray-600">No past courses recorded.</p>
  <% end %>

</div>