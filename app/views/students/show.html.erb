<div class="mx-auto max-w-6xl px-4 py-8">

  <!-- Header -->
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-3xl font-bold text-gray-900"><%= @student.name %></h1>

    <%= link_to "Edit Student",
        edit_student_path(@student),
        class: "inline-flex items-center rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow hover:bg-indigo-500" %>
  </div>

      <!-- Key Info Grid -->
      <dl class="mt-6 grid grid-cols-1 gap-4 sm:grid-cols-3">

        <% if @student.start_date.present? %>
          <div class="rounded-md bg-gray-50 p-4">
            <dt class="text-xs uppercase tracking-wide text-gray-500">Start date</dt>
            <dd class="mt-1 text-sm text-gray-800">
              <%= @student.start_date.strftime("%d %b %Y") %>
            </dd>
          </div>
        <% end %>

        <% if @student.end_date.present? %>
          <div class="rounded-md bg-gray-50 p-4">
            <dt class="text-xs uppercase tracking-wide text-gray-500">End date</dt>
            <dd class="mt-1 text-sm text-gray-800">
              <%= @student.end_date.strftime("%d %b %Y") %>
            </dd>
          </div>
        <% end %>

        <% if @student.status.present? %>
          <div class="rounded-md bg-gray-50 p-4">
            <dt class="text-xs uppercase tracking-wide text-gray-500">Status</dt>
            <dd class="mt-1 text-sm text-gray-800">
              <%= @student.status.capitalize %>
            </dd>
          </div>
        <% end %>


        </dl>
  <h2 class="text-2xl font-semibold text-gray-900 mb-4">Courses</h2>

  <!-- Course Section -->
  <div class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm mb-10">

    <% if @student.course.present? %>
      <div class="text-lg font-medium text-gray-900">
        <%= link_to @student.course.name, @student.course, class: "hover:underline" %>
      </div>

      <% if @student.course.description.present? %>
        <p class="mt-2 text-gray-600"><%= @student.course.description %></p>
      <% end %>



  <!-- Modules Section (paired with the course) -->
    <div class="text-lg font-medium text-gray-900">
      <h2 class="text-2xl font-semibold text-gray-900">Modules</h2>
    </div>

    <% if @student.course.present? %>
      <% course = @student.course %>

      <% if course.course_modules.any? %>
        <ul class="space-y-4">
          <% course.course_modules.order(:name).each do |cm| %>
            <%# Find the student's module by matching name; ideally link by course_module_id in DB for robustness %>
            <% sm = @student.student_modules.find_by(module_name: cm.name) %>

            <% if sm.present? %>
              <%= render "module_status_row", course_module: cm, student_module: sm %>
            <% else %>
              <%# Fallback if missing (e.g., student created before templates were set) %>
              <li class="p-4 bg-amber-50 rounded-lg border border-amber-200">
                <div class="flex items-center justify-between">
                  <div>
                    <h3 class="text-lg font-semibold text-amber-900"><%= cm.name %></h3>
                    <p class="text-sm text-amber-800">No student module found for this template.</p>
                  </div>

                  <%= button_to "Create for Student",
                        student_modules_path(student_module: { student_id: @student.id, module_name: cm.name, status: "SUBMITTED & NOT MARKED" }),
                        method: :post,
                        class: "inline-flex items-center rounded-md bg-amber-600 px-3 py-1.5 text-sm font-semibold text-white hover:bg-amber-500" %>
                </div>
              </li>
            <% end %>

          <% end %>
        </ul>
      <% else %>
        <p class="text-gray-600">This course has no modules yet.</p>
      <% end %>

    <% else %>
      <p class="text-gray-600">No course assigned yet.</p>
    <% end %>
    <% else %>
      <p class="text-gray-600">No course assigned yet.</p>

      <%= link_to "Assign Course",
          edit_student_path(@student),
          class: "mt-2 inline-flex items-center rounded-md bg-blue-600 px-3 py-1.5 text-sm font-medium text-white hover:bg-blue-500" %>
    <% end %>
  </div>

</div>