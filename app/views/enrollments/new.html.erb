<div class="mx-auto max-w-xl p-6 bg-white rounded-lg shadow">
  <h1 class="text-2xl font-semibold mb-4">Enrol <%= @student.name %></h1>

  <%= form_with model: @enrollment do |f| %>

    <%= f.hidden_field :student_id, value: @student.id %>

    <div class="mb-4">
      <%= f.label :course_id, "Select Course", class: "block text-sm font-medium text-gray-700" %>
      <%= f.collection_select :course_id, @courses, :id, :name,
            { prompt: "Choose a course" },
            class: "block w-full border-gray-300 rounded-md shadow-sm" %>
    </div>

    <div class="mb-4">
      <%= f.label :start_date %>
      <%= f.date_field :start_date, class: "block w-full border-gray-300 rounded-md shadow-sm" %>
    </div>

    <div class="mb-4">
      <%= f.label :status %>
      <%= f.select :status,
          [["Active","Active"],["Completed","Completed"],["Withdrawn","Withdrawn"]],
          {},
          class: "block w-full border-gray-300 rounded-md shadow-sm" %>
    </div>

    <%= f.submit "Enrol Student",
        class: "inline-flex items-center rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-500" %>
  <% end %>
</div>