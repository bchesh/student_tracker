<li class="p-4 bg-gray-50 rounded">
  <div class="flex items-center justify-between">
    <strong><%= mod.module_name %></strong>
    <%= module_status_badge(mod.status) %>
  </div>
  <p class="mt-1 text-sm text-gray-600"><%= mod.notes %></p>
  <div class="mt-2 flex gap-3 text-sm">
    <%= link_to "Edit", edit_course_module_path(mod), class: "text-blue-600 hover:underline" %>
    <%= link_to "Delete", mod, data: { turbo_method: :delete, turbo_confirm: "Delete this module?" }, class: "text-red-600 hover:underline" %>
  </div>
</li>