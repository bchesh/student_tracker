<div class="mx-auto max-w-6xl px-4 py-8">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-semibold text-gray-900">Course Modules</h1>
    <%= link_to "Add Module", new_course_module_path, class: "inline-flex items-center rounded-md bg-blue-600 px-4 py-2 text-sm font-semibold text-white shadow hover:bg-blue-500" %>
  </div>

  <div class="overflow-hidden rounded-lg border border-gray-200 bg-white shadow-sm">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider text-gray-600">Module</th>
          <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider text-gray-600">Related Course</th>
          <th class="px-4 py-3 text-right text-xs font-medium uppercase tracking-wider text-gray-600">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100 bg-white">
        <% @course_modules.each do |cm| %>
          <tr class="hover:bg-gray-50">
            <td class="px-4 py-3 text-gray-800 font-medium"><%= cm.name %></td>
            <td class="px-4 py-3 text-gray-700"><%= cm.course&.name %></td>
            <td class="px-4 py-3">
              <div class="flex justify-end gap-2">
                <%= link_to "Edit", edit_course_module_path(cm), class: "inline-flex items-center rounded-md bg-indigo-600 px-3 py-1.5 text-sm font-medium text-white hover:bg-indigo-500" %>
                <%= link_to "Delete", cm, data: { turbo_method: :delete, turbo_confirm: "Delete this module?" }, class: "inline-flex items-center rounded-md bg-red-600 px-3 py-1.5 text-sm font-medium text-white hover:bg-red-500" %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>